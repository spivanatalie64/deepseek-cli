# Example environment variables for the web frontend
# Do NOT commit real secrets into source control.
# Copy this file to web/.env and fill in the values for local development.
# Vite requires client-exposed env vars to be prefixed with VITE_

# Base URL for Deepseek API (default placeholder shown)
VITE_DEEPSEEK_API_BASE=https://api.deepseek.example.com

# Your Deepseek API key (keep this secret; do NOT commit a real key)
VITE_DEEPSEEK_API_KEY=your_api_key_here

# Notes and best-practices:
# - Copy this file to web/.env and set a real VITE_DEEPSEEK_API_KEY for local development.
# - Do NOT commit web/.env containing secrets to version control. Add web/.env to .gitignore if needed.
# - In CI or production, inject VITE_DEEPSEEK_API_KEY as an environment variable; Vite only exposes VITE_* vars to the client.
# - If you prefer runtime entry of the API key, the UI includes an ApiKeyInput component (web/src/components/ApiKeyInput.jsx).
# - If the Deepseek API uses a different endpoint or contract, update VITE_DEEPSEEK_API_BASE accordingly.
